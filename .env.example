# =============================================================================
# BYBIT API CREDENTIALS - CONFIGURACIÓN DE CLAVES
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Reemplaza los valores con tus credenciales reales de Bybit
# 3. NUNCA subas el archivo ".env" a un repositorio público (ya está en .gitignore)
# 4. Para obtener tus API Keys: Bybit > Account > API Management > Create New Key
#    Permisos necesarios: "Contract - Read & Write" y "Unified Trading"
# =============================================================================

# --- CREDENCIALES DE API ---
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# --- ENTORNO (true = Testnet, false = Mainnet REAL) ---
# IMPORTANTE: Usar TESTNET=true para pruebas antes de operar con dinero real
BYBIT_TESTNET=true

# --- CONFIGURACIÓN GENERAL DEL BOT ---
# Par de trading (formato Bybit Futures)
TRADING_SYMBOL=BTCUSDT

# Temporalidad de las velas en minutos
TIMEFRAME=5

# Categoría del mercado: "linear" (USDT Perpetual), "inverse" (Coin-M)
MARKET_CATEGORY=linear

# --- GESTIÓN DE RIESGO ---
# Porcentaje del balance de la cuenta a arriesgar por operación (ej. 0.02 = 2%)
RISK_PER_TRADE=0.02

# Apalancamiento fijo (ej. 5 = 5x)
LEVERAGE=5

# Multiplicador ATR para el Stop Loss (ej. 1.5 significa SL = 1.5 * ATR)
ATR_SL_MULTIPLIER=1.5

# Ratio Riesgo/Beneficio para Take Profit (ej. 2.0 significa TP = 2 * distancia_SL)
RISK_REWARD_RATIO=2.0

# --- CONFIGURACIÓN DE LOGGING ---
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/bot_trading.log
